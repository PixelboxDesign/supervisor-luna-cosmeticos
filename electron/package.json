{
  "name": "supervisor-luna-tray",
  "version": "1.0.0",
  "description": "Supervisor Luna — Bandeja do sistema",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.luna.supervisor",
    "productName": "Supervisor Luna",
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "files": ["main.js", "icon.ico", "!node_modules/**"],
    "extraResources": [
      { "from": "../backend", "to": "backend", "filter": ["**/*", "!node_modules/**"] }
    ]
  }
}
