{
  "name": "supervisor-luna",
  "version": "1.0.0",
  "description": "Supervisor de logs — Luna Cosméticos",
  "scripts": {
    "backend": "node backend/src/server.js",
    "frontend:dev": "cd frontend && npm run dev",
